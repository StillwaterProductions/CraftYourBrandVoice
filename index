  saveDraft();
}
function wordsInDefault(w){
  return [...wordGrid.querySelectorAll('.word-chip')].some(b => b.textContent.trim().toLowerCase() === w.toLowerCase());
}
function addCustomChip(w, select){
  const btn = document.createElement('button');
  btn.className = 'word-chip';
  btn.type = 'button';
  btn.setAttribute('aria-pressed','false');
  btn.textContent = w;
  wordGrid.appendChild(btn);
