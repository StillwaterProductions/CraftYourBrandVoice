// =============== ZAPIER WEBHOOK ===============
// Replace the URL below with your Zapier “Catch Hook” URL (Zapier → New Zap → Webhooks by Zapier → Catch Hook).
// Each submission POSTs as JSON with flat fields ready for Sheets / HubSpot / Mailchimp.
//
const ZAPIER_WEBHOOK_URL = 'https://hooks.zapier.com/hooks/catch/14686569/4ykkn42/';

// Upload the PDF blob to a public file host so Zapier can attach by URL
// (cleanly preserving the .pdf extension, which multipart parts don't).
// tmpfiles.org: free, no API key, CORS-open, 60-minute retention (plenty
// for the email-flight + recipient-open window).
async function uploadPDFForAttachment(blob, filename){
  try {
    const fd = new FormData();
    fd.append('file', blob, filename);
    const r = await fetch('https://tmpfiles.org/api/v1/upload', { method: 'POST', body: fd });
    if (!r.ok) return null;
    const data = await r.json();
    if (data && data.status === 'success' && data.data && data.data.url) {
      // Convert the viewer URL to a direct-download URL by inserting /dl/
      // and upgrade to HTTPS for safe transport in email clients.
      let url = data.data.url.replace('tmpfiles.org/', 'tmpfiles.org/dl/');
      url = url.replace(/^http:\/\//i, 'https://');
      return url;
    }
    return null;
  } catch (err) {
    console.warn('PDF host upload failed:', err);
    return null;
  }
}

async function postToZapier(submission, extras){
