<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>index</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=Instrument+Sans:wght@400;500;600&family=Hanken+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
<style>
  :root{
    --lagoon:#082228;
    --lagoon-80:#3A4E54;
    --lagoon-60:#6B7B7F;
    --lagoon-line:rgba(8,34,40,.18);
    --lagoon-hair:rgba(8,34,40,.10);
    --ivory:#F7F5F0;
    --ivory-90:rgba(247,245,240,.92);
    --ivory-60:rgba(247,245,240,.60);
    --ivory-line:rgba(247,245,240,.22);
    --mist:#D3E3F2;
    --sand:#F9CE8F;
    --mahogany:#421C0B;
    --stone:#9F9A93;

    --font-display:'Manrope',system-ui,sans-serif;
    --font-serif:'Source Serif 4',Georgia,serif;
    --font-body:'Instrument Sans',system-ui,sans-serif;
    --font-support:'Hanken Grotesk',system-ui,sans-serif;
  }

  *{ box-sizing:border-box; }
  html,body{ margin:0; padding:0; }
  body{
    background:var(--ivory);
    color:var(--lagoon);
    font-family:var(--font-body);
    font-size:18px;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }

  ::selection{ background:var(--lagoon); color:var(--ivory); }

  a{ color:inherit; }
  button{ font:inherit; cursor:pointer; }

  .container{ max-width:1180px; margin:0 auto; padding: 0 32px; }
  .narrow{ max-width:820px; margin: 0 auto; padding: 0 32px; }

  /* ---------- Nav ---------- */
  .nav{
    position:sticky; top:0; z-index:50;
    background:var(--ivory);
    border-bottom:1px solid var(--lagoon-line);
  }
  .nav-inner{
    display:flex; align-items:center; justify-content:space-between;
    height:78px;
  }
  .brand-link{
    display:flex; align-items:center; gap:14px;
    text-decoration:none;
    color:var(--lagoon);
  }
  .brand-link .mk{ width:36px; height:36px; color:var(--lagoon); }
  .brand-link .wm{
    font-family:var(--font-display); font-weight:600; font-size:20px;
    letter-spacing:-.01em;
  }
  .brand-link .wm em{
    font-family:var(--font-serif); font-style:italic; font-weight:500;
  }
  .nav-cta{
    background:var(--lagoon); color:var(--ivory);
    border:0; padding: 12px 22px;
    font-family:var(--font-display); font-weight:600;
    font-size:15px;
    border-radius:2px;
    letter-spacing:.02em;
  }

  .progress{
    position:sticky; top:78px; z-index:49;
    background:var(--ivory);
    border-bottom:1px solid var(--lagoon-hair);
  }
  .progress-bar{
    height:3px; background:var(--lagoon-hair);
    position:relative;
  }
  .progress-fill{
    position:absolute; inset:0 100% 0 0;
    background:var(--mahogany);
    transition: right .35s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .progress-label{
    font-family:var(--font-support); font-size:11px;
    letter-spacing:.3em; text-transform:uppercase;
    color:var(--lagoon-60);
    padding: 10px 32px;
    display:flex; justify-content:space-between;
  }

  /* ---------- Hero ---------- */
  .hero{
    background:var(--lagoon); color:var(--ivory);
    padding: 96px 0 120px;
    position:relative; overflow:hidden;
  }
  .hero-eyebrow{
    font-family:var(--font-support);
    letter-spacing:.4em; text-transform:uppercase;
    font-size:13px; color:var(--sand);
    margin-bottom:32px;
  }
  .hero-title{
    font-family:var(--font-display); font-weight:300;
    font-size:clamp(56px, 7vw, 104px);
    line-height:1; letter-spacing:-.02em;
    margin:0 0 32px;
    text-wrap:balance;
    max-width:1000px;
  }
  .hero-title em{ font-family:var(--font-serif); font-style:italic; font-weight:400; }
  .hero-sub{
    font-size:22px; line-height:1.5;
    max-width:680px;
    color:var(--ivory-90);
    margin:0 0 48px;
    text-wrap:pretty;
  }
  .hero-actions{ display:flex; gap:20px; align-items:center; flex-wrap:wrap; }
  .btn-primary{
    background:var(--sand); color:var(--mahogany);
    border:0; padding: 18px 32px;
    font-family:var(--font-display); font-weight:600;
    font-size:17px; letter-spacing:.01em;
    border-radius:2px;
    text-decoration:none;
    display:inline-flex; align-items:center; gap:12px;
    transition: background .18s, transform .18s;
  }
  .btn-primary:hover{ background:#FBD49E; }
  .btn-primary::after{ content:'→'; font-family:var(--font-serif); font-style:italic; }
  .btn-ghost{
    background:transparent; color:var(--ivory);
    border:1px solid var(--ivory-line);
    padding: 18px 28px;
    font-family:var(--font-display); font-weight:500;
    font-size:16px;
    border-radius:2px;
    text-decoration:none;
  }

  .hero-meta{
    margin-top:80px;
    display:grid; grid-template-columns:repeat(3, 1fr);
    gap:48px;
    border-top:1px solid var(--ivory-line);
    padding-top:40px;
  }
  .hero-meta .item .n{
    font-family:var(--font-display); font-weight:300;
    font-size:48px; letter-spacing:-.02em; line-height:1;
    color:var(--sand);
  }
  .hero-meta .item .l{
    font-family:var(--font-support); font-size:13px;
    letter-spacing:.25em; text-transform:uppercase;
    color:var(--ivory-60);
    margin-top:12px;
  }

  /* ---------- Section scaffold ---------- */
  .section{ padding: 96px 0; border-top:1px solid var(--lagoon-line); }
  .section:first-of-type{ border-top:0; }
  .section.alt{ background: #EFEDE6; }
  .step-head{
    display:flex; flex-direction:column; gap:6px;
    margin-bottom:48px;
  }
  .step-num{
    font-family:var(--font-serif); font-style:italic;
    font-size:22px; color:var(--lagoon-60);
  }
  .step-title{
    font-family:var(--font-display); font-weight:600;
    font-size:clamp(40px, 4.5vw, 64px);
    line-height:1.04; letter-spacing:-.02em;
    text-transform:uppercase;
    margin:0;
  }
  .step-lede{
    font-size:21px; line-height:1.5;
    color:var(--lagoon-80);
    max-width:760px;
    margin: 16px 0 0;
  }

  /* ---------- Inputs ---------- */
  label{
    display:block;
    font-family:var(--font-support);
    font-size:13px; letter-spacing:.25em; text-transform:uppercase;
    color:var(--lagoon-60);
    margin-bottom:12px;
  }
  .field-help{
    font-family:var(--font-serif); font-style:italic;
    font-size:16px; color:var(--lagoon-60);
    margin: 6px 0 0;
  }
  .input,
  textarea.input{
    width:100%;
    background:transparent;
    border:0; border-bottom:1px solid var(--lagoon-line);
    padding: 14px 0 16px;
    font-family:var(--font-serif); font-style:italic;
    font-size:22px; line-height:1.4;
    color:var(--lagoon);
    outline:none;
    transition: border-color .18s;
    resize:vertical;
  }
  textarea.input{ min-height:80px; font-style:italic; }
  .input:focus,
  textarea.input:focus{ border-color:var(--mahogany); }
  .input::placeholder, textarea.input::placeholder{ color:var(--lagoon-60); }

  .field-stack{ display:flex; flex-direction:column; gap:36px; }

  /* ---------- Intro cards (Step 01) ---------- */
  .intro-grid{ display:grid; grid-template-columns:repeat(3, 1fr); gap:32px; }
  @media (max-width:780px){ .intro-grid{ grid-template-columns:1fr; } }
  .intro-card{ border-top:1px solid var(--lagoon-line); padding-top:24px; }
  .intro-h{
    font-family:var(--font-support); font-size:12px;
    letter-spacing:.3em; text-transform:uppercase;
    color:var(--lagoon-60);
    margin-bottom:14px;
  }
  .intro-p{ font-size:18px; line-height:1.55; margin:0; color:var(--lagoon-80); }
  .intro-p em{ font-family:var(--font-serif); font-style:italic; color:var(--lagoon); }
  .intro-list{ list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px; }
  .intro-list li{
    font-size:17px; line-height:1.5; color:var(--lagoon-80);
    padding-left:22px; position:relative;
  }
  .intro-list li::before{
    content:'—'; position:absolute; left:0; top:0;
    font-family:var(--font-serif); color:var(--mahogany);
  }

  /* ---------- Voice Chart (Step 04) ---------- */
  .voice-chart{ display:flex; flex-direction:column; }
  .voice-chart-empty{
    border:1px dashed var(--lagoon-line);
    padding:48px 32px;
    text-align:center;
    font-family:var(--font-serif); font-style:italic;
    font-size:20px; color:var(--lagoon-60);
  }
  .voice-chart-empty p{ margin:0; }
  .vc-header{
    display:grid; grid-template-columns: 220px 1fr 1fr;
    gap:32px;
    padding: 12px 0 16px;
    border-bottom:1px solid var(--lagoon);
    font-family:var(--font-support); font-size:12px;
    letter-spacing:.3em; text-transform:uppercase;
    color:var(--lagoon-60);
  }
  .vc-row{
    display:grid; grid-template-columns: 220px 1fr 1fr;
    gap:32px;
    padding:28px 0;
    border-bottom:1px solid var(--lagoon-hair);
  }
  @media (max-width:780px){
    .vc-header{ display:none; }
    .vc-row{ grid-template-columns:1fr; gap:14px; padding:24px 0; }
  }
  .vc-word{
    font-family:var(--font-display); font-weight:600;
    font-size:24px; letter-spacing:-.01em;
    color:var(--lagoon);
  }
  .vc-word small{
    display:block;
    font-family:var(--font-body); font-weight:400;
    font-size:15px; line-height:1.45;
    color:var(--lagoon-60);
    margin-top:8px;
  }
  .vc-do, .vc-not{
    font-family:var(--font-serif); font-style:italic;
    font-size:18px; line-height:1.45;
    color:var(--lagoon);
  }
  .vc-do{ position:relative; padding-left:20px; }
  .vc-not{ position:relative; padding-left:20px; color:var(--lagoon-60); }
  .vc-do::before{ content:'✓'; position:absolute; left:0; top:1px; font-family:var(--font-body); font-style:normal; color:var(--mahogany); font-weight:600; }
  .vc-not::before{ content:'×'; position:absolute; left:0; top:1px; font-family:var(--font-body); font-style:normal; color:var(--stone); font-weight:600; font-size:20px; }
  @media (max-width:780px){
    .vc-do::before, .vc-not::before{ position:static; margin-right:8px; }
  }

  /* ---------- Word Bank ---------- */
  .word-grid{
    display:grid; grid-template-columns:repeat(5, 1fr);
    gap:16px 18px;
  }
  @media (max-width:780px){ .word-grid{ grid-template-columns:repeat(2, 1fr); } }
  .word-chip{
    appearance:none;
    background:transparent; color:var(--lagoon);
    border:1px solid var(--lagoon-line);
    font-family:var(--font-body); font-size:18px;
    padding: 14px 12px;
    border-radius:999px;
    transition: background .18s, color .18s, border-color .18s;
  }
  .word-chip:hover{ border-color:var(--lagoon); }
  .word-chip[aria-pressed="true"]{
    background:var(--lagoon); color:var(--ivory);
    border-color:var(--lagoon);
  }
  .word-counter{
    margin-top:28px;
    font-family:var(--font-support); font-size:13px;
    letter-spacing:.25em; text-transform:uppercase;
    color:var(--lagoon-60);
  }
  .word-counter b{
    font-family:var(--font-display); font-weight:600;
    color:var(--lagoon);
    font-size:18px; letter-spacing:0; text-transform:none;
    margin: 0 6px;
  }
  .add-word-row{ margin-top:18px; display:flex; gap:12px; align-items:center; }
  .add-word-row input{
    flex:1;
    background:transparent;
    border:1px dashed var(--lagoon-line);
    padding: 12px 16px;
    font-family:var(--font-body); font-size:16px;
    border-radius:999px;
    color:var(--lagoon);
    outline:none;
  }
  .add-word-row button{
    background:var(--lagoon); color:var(--ivory);
    border:0; padding: 12px 22px; border-radius:999px;
    font-family:var(--font-display); font-weight:600; font-size:14px;
  }

  /* ---------- Tone Sliders ---------- */
  .tone-list{ display:flex; flex-direction:column; gap:18px; }
  .tone-row{
    display:grid; grid-template-columns: 180px 1fr 180px;
    align-items:center; gap:24px;
  }
  @media (max-width:780px){ .tone-row{ grid-template-columns: 100px 1fr 100px; gap:12px; } }
  .tone-end{
    font-family:var(--font-body); font-size:17px;
    padding: 11px 20px;
    border:1px solid var(--lagoon-line);
    border-radius:999px;
    text-align:center;
    transition: background .18s, color .18s, border-color .18s;
    user-select:none;
  }
  .tone-row.l-active .tone-end.l,
  .tone-row.r-active .tone-end.r{
    background:var(--lagoon); color:var(--ivory); border-color:var(--lagoon);
  }
  .tone-track{
    position:relative; height:2px;
    background:var(--lagoon-line);
    cursor:pointer;
  }
  .tone-track::before{
    content:''; position:absolute;
    left:50%; top:-6px; bottom:-6px;
    width:1px;
    background:var(--lagoon-line);
    transform:translateX(-50%);
    pointer-events:none;
  }
  .tone-track::after{ content:''; position:absolute; inset:-22px 0; }
  .tone-dot{
    position:absolute; top:50%;
    width:20px; height:20px;
    background:var(--lagoon);
    border-radius:999px;
    transform:translate(-50%, -50%);
    transition: left .35s cubic-bezier(0.2,0.7,0.2,1);
    pointer-events:none;
  }

  /* ---------- Strengths / Pillars ---------- */
  .strengths-list{ list-style:none; padding:0; margin: 0; display:flex; flex-direction:column; gap:24px; }
  .strength-row{
    display:grid; grid-template-columns: 56px 1fr; gap:20px; align-items:end;
  }
  .strength-row .n{
    font-family:var(--font-serif); font-style:italic;
    font-size:22px; color:var(--lagoon-60);
    padding-bottom:14px;
  }
  .pillars{ display:flex; flex-direction:column; gap:36px; }
  .pillar-head{
    background:var(--lagoon); color:var(--ivory);
    padding: 12px 24px;
    font-family:var(--font-display); font-weight:600; font-size:18px;
    letter-spacing:.08em; text-transform:uppercase;
  }
  .pillar-suggest{ display:flex; gap:10px; padding: 14px 0 0; flex-wrap:wrap; }
  .pillar-suggest .sug{
    font-family:var(--font-body); font-size:14px;
    color:var(--lagoon-60);
    border:1px solid var(--lagoon-line);
    padding:6px 14px;
    border-radius:999px;
    background:transparent;
  }
  .pillar-suggest .sug:hover{ background:var(--lagoon); color:var(--ivory); border-color:var(--lagoon); }

  /* ---------- Generate CTA ---------- */
  .generate-band{
    background:var(--mahogany); color:var(--ivory);
    padding: 96px 0;
    text-align:center;
  }
  .generate-band h2{
    font-family:var(--font-display); font-weight:300;
    font-size:clamp(44px, 5vw, 76px);
    line-height:1.04; letter-spacing:-.02em;
    margin: 0 0 24px;
  }
  .generate-band h2 em{ font-family:var(--font-serif); font-style:italic; font-weight:400; }
  .generate-band p{
    font-size:21px; max-width:640px; margin: 0 auto 40px;
    color:rgba(247,245,240,.85);
  }
  .generate-band .btn-primary{ font-size:19px; padding: 22px 40px; }

  .checklist{
    display:grid; grid-template-columns:repeat(3, 1fr);
    max-width:920px; margin: 64px auto 0;
    gap:32px;
    text-align:left;
  }
  @media (max-width:780px){ .checklist{ grid-template-columns:1fr; } }
  .check-item{
    border-top:1px solid var(--ivory-line);
    padding-top:24px;
  }
  .check-item .l{
    font-family:var(--font-support); font-size:11px;
    letter-spacing:.3em; text-transform:uppercase;
    color:var(--sand);
  }
  .check-item .v{
    font-family:var(--font-serif); font-style:italic;
    font-size:24px; margin-top:8px;
  }
  .check-item.done .v::before{ content:'✓  '; font-style:normal; color:var(--sand); }

  /* ---------- Modal ---------- */
  .modal-scrim{
    position:fixed; inset:0;
    background:rgba(8,34,40,.78);
    backdrop-filter: blur(6px);
    z-index:100;
    display:flex; align-items:center; justify-content:center;
    padding:24px;
    opacity:0; pointer-events:none;
    transition: opacity .25s;
  }
  .modal-scrim.show{ opacity:1; pointer-events:auto; }
  .modal{
    background:var(--ivory);
    width:100%; max-width:540px;
    padding: 56px 56px 48px;
    transform: translateY(20px); opacity:0;
    transition: transform .3s cubic-bezier(0.2,0.7,0.2,1), opacity .25s;
    position:relative;
  }
  .modal-scrim.show .modal{ transform:none; opacity:1; }
  .modal-close{
    position:absolute; top:20px; right:24px;
    background:transparent; border:0;
    font-size:24px; color:var(--lagoon-60);
    padding:8px;
  }
  .modal h3{
    font-family:var(--font-display); font-weight:400;
    font-size:36px; letter-spacing:-.01em; line-height:1.1;
    margin: 0 0 12px;
  }
  .modal h3 em{ font-family:var(--font-serif); font-style:italic; font-weight:500; }
  .modal p.lede{ color:var(--lagoon-80); font-size:17px; margin: 0 0 32px; }
  .modal .field-stack{ gap:24px; }
  .modal label{ margin-bottom:6px; }
  .modal .input{ font-style:normal; font-family:var(--font-body); font-size:18px; }
  .modal .actions{ margin-top:36px; display:flex; flex-direction:column; gap:14px; }
  .modal .btn-primary{ justify-content:center; padding: 16px 24px; }
  .modal .fineprint{
    font-family:var(--font-body); font-size:13px;
    color:var(--lagoon-60);
    text-align:center; line-height:1.5;
  }

  /* ---------- Result (Brand Voice Sheet) ---------- */
  .result-view{
    position:fixed; inset:0;
    background:var(--ivory);
    z-index:90;
    overflow-y:auto;
    display:none;
  }
  .result-view.show{ display:block; }
  .result-toolbar{
    position:sticky; top:0; z-index:5;
    background:var(--ivory);
    border-bottom:1px solid var(--lagoon-line);
    padding: 16px 32px;
    display:flex; align-items:center; justify-content:space-between;
    gap:16px; flex-wrap:wrap;
  }
  .result-toolbar .who{
    font-family:var(--font-body); font-size:14px; color:var(--lagoon-60);
  }
  .result-toolbar .who b{ color:var(--lagoon); font-weight:600; }
  .result-toolbar .tools{ display:flex; gap:10px; }
  .toolbtn{
    background:transparent; color:var(--lagoon);
    border:1px solid var(--lagoon-line);
    padding: 10px 18px; border-radius:2px;
    font-family:var(--font-display); font-weight:500; font-size:14px;
  }
  .toolbtn.primary{ background:var(--lagoon); color:var(--ivory); border-color:var(--lagoon); }
  .send-status{
    font-family:var(--font-support); font-size:11px;
    letter-spacing:.25em; text-transform:uppercase;
    color:var(--lagoon-60);
    margin-left:12px;
    transition: color .2s;
  }
  .send-status.ok{ color:var(--mahogany); }

  .sheet{
    max-width:920px;
    margin: 48px auto 96px;
    padding: 0 48px;
  }
  .sheet-header{
    border-bottom:1px solid var(--lagoon-line);
    padding-bottom:32px;
    margin-bottom:48px;
  }
  .sheet-header .eyebrow{
    font-family:var(--font-support); font-size:12px;
    letter-spacing:.3em; text-transform:uppercase;
    color:var(--lagoon-60);
  }
  .sheet-header h1{
    font-family:var(--font-display); font-weight:300;
    font-size:64px; line-height:1; letter-spacing:-.02em;
    margin: 16px 0 4px;
  }
  .sheet-header h1 em{ font-family:var(--font-serif); font-style:italic; font-weight:400; }
  .sheet-header .for{
    font-family:var(--font-serif); font-style:italic;
    font-size:22px; color:var(--lagoon-80);
    margin-top:8px;
  }

  .sheet-section{
    margin-bottom:48px;
  }
  .sheet-section h2{
    font-family:var(--font-support); font-weight:500;
    font-size:12px; letter-spacing:.3em; text-transform:uppercase;
    color:var(--lagoon-60);
    margin: 0 0 16px;
  }
  .sheet-statement{
    font-family:var(--font-serif); font-weight:300;
    font-size:34px; line-height:1.3; letter-spacing:-.01em;
    color:var(--lagoon);
    text-wrap:pretty;
    margin:0;
  }
  .sheet-statement em{ font-style:italic; }

  .sheet-words{ display:flex; flex-wrap:wrap; gap:10px 12px; }
  .sheet-word{
    background:var(--lagoon); color:var(--ivory);
    padding: 10px 20px;
    border-radius:999px;
    font-family:var(--font-body); font-size:17px;
  }

  .sheet-tones{ display:flex; flex-direction:column; gap:14px; }
  .sheet-tone{
    display:grid; grid-template-columns: 140px 1fr 140px;
    align-items:center; gap:18px;
  }
  .sheet-tone .e{ font-family:var(--font-body); font-size:16px; color:var(--lagoon-60); }
  .sheet-tone .e.active{ color:var(--lagoon); font-weight:500; }
  .sheet-tone .bar{
    position:relative; height:2px; background:var(--lagoon-line);
  }
  .sheet-tone .bar i{
    position:absolute; top:50%; width:14px; height:14px;
    background:var(--mahogany); border-radius:999px;
    transform:translate(-50%, -50%);
  }
  .sheet-tone .e.r{ text-align:right; }
  .sheet-tone .bar::before{
    content:''; position:absolute; left:50%; top:-4px; bottom:-4px;
    width:1px; background:var(--lagoon-hair); transform:translateX(-50%);
  }

  /* sheet voice chart */
  .sheet-vc-row{
    display:grid; grid-template-columns: 140px 1fr 1fr;
    gap:24px; padding:18px 0;
    border-bottom:1px solid var(--lagoon-hair);
  }
  .sheet-vc-row .w{ font-family:var(--font-display); font-weight:600; font-size:18px; }
  .sheet-vc-row .d, .sheet-vc-row .n{
    font-family:var(--font-serif); font-style:italic; font-size:16px; line-height:1.45;
  }
  .sheet-vc-row .n{ color:var(--lagoon-60); }
  @media (max-width:720px){ .sheet-vc-row{ grid-template-columns:1fr; gap:8px; } }

  .sheet-grid-2{
    display:grid; grid-template-columns:1fr 1fr; gap: 40px;
  }
  @media (max-width:720px){ .sheet-grid-2{ grid-template-columns:1fr; } }

  .sheet-list{
    list-style:none; padding:0; margin: 0;
    display:flex; flex-direction:column; gap:12px;
  }
  .sheet-list li{
    font-family:var(--font-body); font-size:18px; line-height:1.5;
    padding: 12px 0;
    border-bottom:1px solid var(--lagoon-hair);
    display:flex; gap:16px;
  }
  .sheet-list li::before{
    content: counter(item, decimal-leading-zero);
    counter-increment: item;
    font-family:var(--font-serif); font-style:italic;
    color:var(--lagoon-60); font-size:14px;
    min-width:24px;
    padding-top:4px;
  }
  .sheet-list{ counter-reset: item; }

  .pillar-card{
    border-top:1px solid var(--lagoon-line);
    padding-top:20px;
  }
  .pillar-card .h{
    font-family:var(--font-display); font-weight:600;
    font-size:14px; letter-spacing:.15em; text-transform:uppercase;
    color:var(--lagoon-60);
    margin: 0 0 8px;
  }
  .pillar-card .p{
    font-family:var(--font-serif); font-style:italic;
    font-size:22px; line-height:1.35;
    margin:0;
  }

  .sheet-footer{
    margin-top: 80px; padding-top:32px;
    border-top:1px solid var(--lagoon-line);
    display:flex; justify-content:space-between; align-items:end;
    font-family:var(--font-body); font-size:14px; color:var(--lagoon-60);
  }
  .sheet-footer .stamp{
    display:flex; align-items:center; gap:12px;
  }
  .sheet-footer .stamp .mk{ width:28px; height:28px; color:var(--lagoon); }
  .sheet-footer .stamp .wm{
    font-family:var(--font-display); font-weight:600; font-size:15px;
  }
  .sheet-footer .stamp .wm em{ font-family:var(--font-serif); font-style:italic; font-weight:500; }

  .sheet-loading{
    text-align:center;
    padding: 80px 0;
    font-family:var(--font-serif); font-style:italic;
    font-size:22px;
    color:var(--lagoon-60);
  }
  .sheet-loading .dots::after{
    content:''; animation: dots 1.4s infinite;
  }
  @keyframes dots{
    0%,20%{ content:'.'; }
    40%{ content:'..'; }
    60%,100%{ content:'...'; }
  }

  /* ---------- Print: only the sheet ---------- */
  @media print{
    .nav, .progress, .hero, .section, .generate-band, .modal-scrim,
    .result-toolbar{ display:none !important; }
    body{ background:#fff; }
    .result-view{ position:static; display:block !important; }
    .sheet{ margin:0; padding: 24px 32px; max-width:none; }
    .sheet-statement{ font-size:24px; }
    .sheet-header h1{ font-size:42px; }
  }

  /* ---------- Admin ---------- */
  .admin-view{
    display:none;
    padding: 64px 0 96px;
    background: #EFEDE6;
    min-height:100vh;
  }
  body.admin .admin-view{ display:block; }
  body.admin .nav, body.admin .progress, body.admin .hero,
  body.admin .section, body.admin .generate-band{ display:none; }
  .admin-header{
    display:flex; align-items:end; justify-content:space-between;
    margin-bottom:48px;
    border-bottom:1px solid var(--lagoon-line);
    padding-bottom:24px;
  }
  .admin-header h1{
    font-family:var(--font-display); font-weight:600;
    font-size:48px; letter-spacing:-.02em;
    margin:0;
  }
  .admin-table{
    width:100%; border-collapse:collapse;
    background:var(--ivory);
  }
  .admin-table th, .admin-table td{
    text-align:left; padding: 16px 20px;
    border-bottom:1px solid var(--lagoon-hair);
    font-size:15px;
  }
  .admin-table th{
    font-family:var(--font-support); font-size:12px;
    letter-spacing:.2em; text-transform:uppercase;
    color:var(--lagoon-60);
    background:#EFEDE6;
  }
  .admin-table tbody tr:hover{ background:#FAF8F2; cursor:pointer; }
  .admin-empty{
    padding:64px;
    text-align:center;
    font-family:var(--font-serif); font-style:italic;
    color:var(--lagoon-60);
    background:var(--ivory);
    font-size:20px;
  }
  .admin-tools{ display:flex; gap:10px; align-items:center; }

  /* helper: scroll target offset */
  .anchor{ scroll-margin-top: 100px; }
</style>
</head>
<body>

<!-- Brand symbol path (extracted from logo-symbol.svg) reused via CSS classes below as inline SVG -->

<!-- ============ NAV ============ -->
<header class="nav">
  <div class="container nav-inner">
    <a class="brand-link" href="#top">
      <svg class="mk" viewBox="0 0 185.3025 185.3025" xmlns="http://www.w3.org/2000/svg"><path d="M185.3025,123.5349v3.7002c0,32.0697-25.9976,58.0673-58.0673,58.0673h0v-119.8348h0c32.0697,0,58.0673,25.9976,58.0673,58.0673ZM65.4676,0c0,32.0697,25.9976,58.0673,58.0673,58.0673h61.7675c0-32.0697-25.9976-58.0674-58.0673-58.0674h-61.7675ZM0,127.2352c0,32.0697,25.9976,58.0673,58.0673,58.0673h61.7675c0-32.0697-25.9976-58.0674-58.0673-58.0674H0ZM58.0673,0C25.9976,0,0,25.9976,0,58.0673v3.7002c0,32.0697,25.9976,58.0673,58.0673,58.0673h0V0h0Z" fill="currentColor"/></svg>
