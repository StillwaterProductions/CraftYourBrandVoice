//
const toneRows = [...document.querySelectorAll('#toneList .tone-row')];
toneRows.forEach((row, idx) => {
  const track = row.querySelector('.tone-track');
  const dot = row.querySelector('.tone-dot');
  const initialPct = (idx in state.tones) ? state.tones[idx] : 50;
  setPct(initialPct);
  function setPct(pct){
    pct = Math.max(0, Math.min(100, pct));
    dot.style.left = pct + '%';
    row.classList.toggle('l-active', pct < 40);
    row.classList.toggle('r-active', pct > 60);
    state.tones[idx] = pct;
  }
  function fromX(x){
    const r = track.getBoundingClientRect();
    return ((x - r.left) / r.width) * 100;
  }
  track.addEventListener('click', e => { setPct(fromX(e.clientX)); saveDraft(); updateProgress(); });
  let dragging = false;
  track.addEventListener('pointerdown', e => { dragging = true; track.setPointerCapture(e.pointerId); setPct(fromX(e.clientX)); });
  track.addEventListener('pointermove', e => { if (dragging) setPct(fromX(e.clientX)); });
  track.addEventListener('pointerup',   e => { dragging = false; saveDraft(); updateProgress(); });
});

