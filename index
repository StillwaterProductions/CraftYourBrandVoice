<!-- progress -->
<div class="progress">
  <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
  <div class="progress-label">
    <span>Your brand voice in 7 steps</span>
    <span><b id="progressNum">0</b>% complete</span>
  </div>
</div>

<!-- ============ HERO ============ -->
<section id="top" class="hero">
  <div class="container">
    <div class="hero-eyebrow">Free workbook · For realtors &amp; business owners</div>
    <h1 class="hero-title">Craft a brand voice your buyers <em>actually</em> remember.</h1>
    <p class="hero-sub">Most agents lose deals to whichever listing looks most expensive online. Spend the next ten minutes building the voice that makes yours the one that does. We will write you a personalized one-page brand voice sheet at the end — yours to keep.</p>
    <div class="hero-actions">
      <a class="btn-primary" href="#workshop">Start the workshop</a>
      <a class="btn-ghost" href="#what-you-get">What you get</a>
    </div>
    <div class="hero-meta">
      <div class="item"><div class="n">7</div><div class="l">Short exercises</div></div>
      <div class="item"><div class="n">10<span style="font-size:24px; letter-spacing:0;"> min</span></div><div class="l">Average completion</div></div>
      <div class="item"><div class="n">1</div><div class="l">Personalized brand voice sheet</div></div>
    </div>
  </div>
</section>

<!-- ============ WORKSHOP ============ -->
<main id="workshop">

  <!-- Step 01: What is Brand Voice -->
  <section class="section" id="step-intro">
    <div class="narrow anchor">
      <div class="step-head">
        <span class="step-num">Step 01</span>
        <h2 class="step-title">What Is a Brand Voice?</h2>
        <p class="step-lede">Your brand voice is the consistent personality behind every word you publish — listing copy, captions, emails, the way you answer the phone. Two agents can sell the same house. Only one of them sounds like <em>them</em>.</p>
      </div>

      <div class="intro-grid">
        <div class="intro-card">
          <div class="intro-h">Why it matters</div>
          <p class="intro-p">Buyers and sellers do not remember features. They remember how you made them feel. A consistent voice is the fastest way to be remembered, referred, and chosen over the agent down the street who sounds like every other agent.</p>
        </div>
        <div class="intro-card">
          <div class="intro-h">What you'll build today</div>
          <ul class="intro-list">
            <li>The three sentences that anchor your brand</li>
            <li>Three to seven words that describe how you sound</li>
            <li>A do-this / not-this chart you can hand to anyone writing for you</li>
            <li>Your tone, your strengths, and the three content pillars you'll publish against</li>
          </ul>
        </div>
        <div class="intro-card">
          <div class="intro-h">How to use it</div>
          <p class="intro-p">Ten minutes. Five steps. At the end you'll get a one-page Brand Voice Sheet — yours to share with VAs, photographers, social managers, or anyone writing on your behalf so they sound like <em>you</em>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 02: Brand Essentials -->
  <section class="section alt" id="step-essentials">
    <div class="narrow anchor">
      <div class="step-head">
        <span class="step-num">Step 02</span>
        <h2 class="step-title">Your Brand Essentials</h2>
        <p class="step-lede">Three short answers. Don't overthink — write what you'd actually say to a friend at a soccer game.</p>
      </div>

      <div class="field-stack">
        <div>
          <label>Brand mission</label>
          <textarea class="input" data-field="mission" placeholder="What you do, for whom, and why it matters — in one sentence." rows="2"></textarea>
        </div>
        <div>
          <label>Brand vision</label>
          <textarea class="input" data-field="vision" placeholder="The future you are working toward. The world you are building." rows="2"></textarea>
        </div>
        <div>
          <label>Elevator pitch</label>
          <textarea class="input" data-field="pitch" placeholder="“I help [who] do [what] so they can [outcome] — without [pain].”" rows="2"></textarea>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 03: Word Bank -->
  <section class="section" id="step-words">
    <div class="container anchor">
      <div class="step-head">
        <span class="step-num">Step 03</span>
        <h2 class="step-title">Branding Word Bank</h2>
        <p class="step-lede">Tap three to seven words that describe how your brand sounds. Skip what you would never call yourself. Add your own if a word is missing.</p>
      </div>

      <div class="word-grid" id="wordGrid">
        <button class="word-chip" type="button" aria-pressed="false">Calm</button>
        <button class="word-chip" type="button" aria-pressed="false">Authentic</button>
        <button class="word-chip" type="button" aria-pressed="false">Creative</button>
        <button class="word-chip" type="button" aria-pressed="false">Bold</button>
        <button class="word-chip" type="button" aria-pressed="false">Reliable</button>
        <button class="word-chip" type="button" aria-pressed="false">Confident</button>
        <button class="word-chip" type="button" aria-pressed="false">Honest</button>
        <button class="word-chip" type="button" aria-pressed="false">Bespoke</button>
        <button class="word-chip" type="button" aria-pressed="false">Energetic</button>
        <button class="word-chip" type="button" aria-pressed="false">Cheerful</button>
        <button class="word-chip" type="button" aria-pressed="false">Trendy</button>
        <button class="word-chip" type="button" aria-pressed="false">Professional</button>
        <button class="word-chip" type="button" aria-pressed="false">Luxurious</button>
        <button class="word-chip" type="button" aria-pressed="false">Sustainable</button>
        <button class="word-chip" type="button" aria-pressed="false">Casual</button>
        <button class="word-chip" type="button" aria-pressed="false">Warm</button>
        <button class="word-chip" type="button" aria-pressed="false">Direct</button>
        <button class="word-chip" type="button" aria-pressed="false">Practical</button>
        <button class="word-chip" type="button" aria-pressed="false">Refined</button>
        <button class="word-chip" type="button" aria-pressed="false">Witty</button>
      </div>

      <div class="add-word-row">
        <input id="customWord" type="text" placeholder="Add your own word…" />
        <button type="button" id="addWordBtn">Add</button>
      </div>

      <p class="word-counter">Selected <b id="wordCount">0</b> of 3–7 · click to toggle</p>
    </div>
  </section>

  <!-- Step 04: Brand Voice Chart (auto-populated) -->
  <section class="section alt" id="step-chart">
    <div class="container anchor">
      <div class="step-head">
        <span class="step-num">Step 04</span>
        <h2 class="step-title">Your Brand Voice Chart</h2>
        <p class="step-lede">This chart populates automatically from the words you selected. Each row gives you a Do This / Not This example so you (or anyone writing for you) can hear the voice in action.</p>
      </div>

      <div id="voiceChart" class="voice-chart">
        <div class="voice-chart-empty">
          <p>Pick at least three words in Step 03 to see your chart build itself.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Step 05: Tone of Voice -->
  <section class="section" id="step-tone">
    <div class="container anchor">
      <div class="step-head">
        <span class="step-num">Step 05</span>
        <h2 class="step-title">Tone of Voice</h2>
        <p class="step-lede">Drag the dot on each spectrum. Most brands land on a complementary pair — usually one warmth lever and one authority lever.</p>
      </div>

      <div class="tone-list" id="toneList">
        <div class="tone-row" data-l="Modern" data-r="Classic"><div class="tone-end l">Modern</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Classic</div></div>
        <div class="tone-row" data-l="Fun" data-r="Serious"><div class="tone-end l">Fun</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Serious</div></div>
        <div class="tone-row" data-l="Bold" data-r="Subtle"><div class="tone-end l">Bold</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Subtle</div></div>
        <div class="tone-row" data-l="Approachable" data-r="Exclusive"><div class="tone-end l">Approachable</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Exclusive</div></div>
        <div class="tone-row" data-l="Creative" data-r="Practical"><div class="tone-end l">Creative</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Practical</div></div>
        <div class="tone-row" data-l="Playful" data-r="Professional"><div class="tone-end l">Playful</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Professional</div></div>
        <div class="tone-row" data-l="Warm" data-r="Authoritative"><div class="tone-end l">Warm</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Authoritative</div></div>
        <div class="tone-row" data-l="Trendy" data-r="Established"><div class="tone-end l">Trendy</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Established</div></div>
        <div class="tone-row" data-l="Innovative" data-r="Traditional"><div class="tone-end l">Innovative</div><div class="tone-track"><div class="tone-dot" style="left:50%;"></div></div><div class="tone-end r">Traditional</div></div>
      </div>
    </div>
  </section>

  <!-- Step 06: Strengths -->
  <section class="section alt" id="step-strengths">
    <div class="narrow anchor">
      <div class="step-head">
        <span class="step-num">Step 06</span>
        <h2 class="step-title">Your Strengths</h2>
        <p class="step-lede">What do past clients praise you for? Pull from testimonials, from texts, from the things people thank you for at closing. Five lines.</p>
      </div>

      <ul class="strengths-list" id="strengthsList">
        <li class="strength-row"><span class="n">01</span><input class="input" data-field="strength-1" type="text" placeholder="e.g. I know every street in North Scottsdale by name." /></li>
        <li class="strength-row"><span class="n">02</span><input class="input" data-field="strength-2" type="text" placeholder="e.g. I have closed 14 multi-offer situations in 2025 alone." /></li>
        <li class="strength-row"><span class="n">03</span><input class="input" data-field="strength-3" type="text" placeholder="e.g. My clients describe me as the calmest person in the room." /></li>
        <li class="strength-row"><span class="n">04</span><input class="input" data-field="strength-4" type="text" placeholder="e.g. I get listings to professional photographers within 48 hours." /></li>
        <li class="strength-row"><span class="n">05</span><input class="input" data-field="strength-5" type="text" placeholder="e.g. I have a contractor on call for any pre-listing repair." /></li>
      </ul>
    </div>
  </section>

  <!-- Step 07: Content Pillars -->
  <section class="section" id="step-pillars">
    <div class="narrow anchor">
      <div class="step-head">
        <span class="step-num">Step 07</span>
        <h2 class="step-title">Content Pillars</h2>
        <p class="step-lede">Three themes that anchor every piece of content. Every post fits under one — or it does not get made.</p>
      </div>

      <div class="pillars">
        <div class="pillar">
          <div class="pillar-head">Pillar 1 · The Neighborhood</div>
          <input class="input" data-field="pillar-1" type="text" placeholder="What you know about this market that nobody else does" />
          <div class="pillar-suggest">
            <button class="sug" type="button">Market updates</button>
            <button class="sug" type="button">Hidden gems</button>
            <button class="sug" type="button">Schools &amp; lifestyle</button>
            <button class="sug" type="button">Local business spotlights</button>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-head">Pillar 2 · The Process</div>
          <input class="input" data-field="pillar-2" type="text" placeholder="How you actually do the work — buying, selling, prepping a home" />
          <div class="pillar-suggest">
            <button class="sug" type="button">Behind the listing</button>
            <button class="sug" type="button">Buyer Q&amp;A</button>
            <button class="sug" type="button">Pre-listing checklist</button>
            <button class="sug" type="button">Closing day</button>
          </div>
        </div>
        <div class="pillar">
          <div class="pillar-head">Pillar 3 · The Person</div>
          <input class="input" data-field="pillar-3" type="text" placeholder="The human behind the brand — why anyone would trust you" />
          <div class="pillar-suggest">
            <button class="sug" type="button">Client wins</button>
            <button class="sug" type="button">Team &amp; partners</button>
            <button class="sug" type="button">A day in the life</button>
            <button class="sug" type="button">Why I do this</button>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- ============ GENERATE BAND ============ -->
<section class="generate-band" id="what-you-get">
  <div class="container">
    <h2>Get your <em>brand voice</em> sheet.</h2>
    <p>One page. Personalized to your answers. Yours to share with anyone writing for you — VAs, photographers, social managers.</p>
    <button class="btn-primary" type="button" id="generateBtn">Generate my brand voice</button>

    <div class="checklist" id="checklist">
      <div class="check-item" data-check="essentials"><div class="l">Step 02</div><div class="v">Brand essentials</div></div>
      <div class="check-item" data-check="words"><div class="l">Step 03</div><div class="v">Word bank</div></div>
      <div class="check-item" data-check="chart"><div class="l">Step 04</div><div class="v">Voice chart</div></div>
      <div class="check-item" data-check="tone"><div class="l">Step 05</div><div class="v">Tone of voice</div></div>
      <div class="check-item" data-check="strengths"><div class="l">Step 06</div><div class="v">Your strengths</div></div>
      <div class="check-item" data-check="pillars"><div class="l">Step 07</div><div class="v">Content pillars</div></div>
    </div>
  </div>
</section>

<!-- ============ CONTACT MODAL ============ -->
<div class="modal-scrim" id="contactScrim" role="dialog" aria-modal="true" aria-labelledby="contactTitle">
  <div class="modal" role="document">
    <button class="modal-close" type="button" aria-label="Close" id="modalClose">×</button>
    <h3 id="contactTitle">One more step before your <em>brand voice</em>.</h3>
    <p class="lede">Where should we send your one-page brand voice sheet?</p>
    <form id="contactForm" novalidate>
      <div class="field-stack">
        <div>
          <label for="cf-name">Full name</label>
          <input class="input" id="cf-name" name="name" type="text" required autocomplete="name" placeholder="Jordan Trofan" />
        </div>
        <div>
          <label for="cf-email">Email</label>
          <input class="input" id="cf-email" name="email" type="email" required autocomplete="email" placeholder="you@brokerage.com" />
        </div>
        <div>
          <label for="cf-phone">Phone</label>
          <input class="input" id="cf-phone" name="phone" type="tel" required autocomplete="tel" placeholder="(555) 555-0142" />
        </div>
      </div>
      <div class="actions">
        <button class="btn-primary" type="submit">Generate my brand voice</button>
        <span class="fineprint">We will use this to send you your sheet and one short follow-up. No spam.</span>
      </div>
    </form>
  </div>
</div>

<!-- ============ RESULT VIEW ============ -->
<div class="result-view" id="resultView" aria-hidden="true">
  <div class="result-toolbar">
    <div class="who">Brand voice for <b id="rv-name">—</b><span class="send-status" id="sendStatus"></span></div>
    <div class="tools">
      <button class="toolbtn" type="button" id="rv-back">← Back to edit</button>
      <button class="toolbtn" type="button" onclick="window.print()">Download / Print</button>
      <button class="toolbtn primary" type="button" id="rv-book">Book free consult</button>
    </div>
