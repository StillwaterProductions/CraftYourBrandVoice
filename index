//
// =============== PDF GENERATION (client-side) ===============
// Renders the .sheet element to a PDF blob, returns { filename, base64 }.
// PDF is generated AFTER the result view is shown and the voice statement is set.
//
async function generateSheetPDF(submission){
  if (!window.htmlToImage || !window.jspdf) return null;
  const sheet = document.querySelector('#resultView .sheet');
  if (!sheet) return null;
  try {
    if (document.fonts && document.fonts.ready) {
      await document.fonts.ready;
    }
    await new Promise(r => requestAnimationFrame(() => r()));

    // html-to-image handles CSS variables, web fonts, and modern CSS better than html2canvas.
    // Uses SVG foreignObject embedding, which renders the actual browser-painted DOM.
    const dataUrl = await window.htmlToImage.toJpeg(sheet, {
      quality: 0.95,
      backgroundColor: '#F7F5F0',
      pixelRatio: 2,
      cacheBust: true
    });

    // load the captured image so we know its real dimensions
    const img = new Image();
    await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = dataUrl; });

    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ unit: 'pt', format: 'letter', orientation: 'portrait' });
    const pageW = pdf.internal.pageSize.getWidth();   // 612
    const pageH = pdf.internal.pageSize.getHeight();  // 792
    const margin = 28;
    const usableW = pageW - margin * 2;
    const usableH = pageH - margin * 2;

    // map image height into PDF points; slice across multiple pages if needed
    const renderedScale = usableW / img.width;
    const totalRenderedH = img.height * renderedScale;

    if (totalRenderedH <= usableH) {
      pdf.addImage(dataUrl, 'JPEG', margin, margin, usableW, totalRenderedH, undefined, 'FAST');
    } else {
      // how many source-image pixels fit on one page
      const pxPerPage = usableH / renderedScale;
      let y = 0;
      let pageIndex = 0;
      while (y < img.height) {
        if (pageIndex > 0) pdf.addPage();
        const sliceH = Math.min(pxPerPage, img.height - y);
        const canvas = document.createElement('canvas');
        canvas.width = img.width;
        canvas.height = sliceH;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#F7F5F0';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, -y);
        const sliceUrl = canvas.toDataURL('image/jpeg', 0.95);
        const renderedH = sliceH * renderedScale;
        pdf.addImage(sliceUrl, 'JPEG', margin, margin, usableW, renderedH, undefined, 'FAST');
        y += pxPerPage;
        pageIndex++;
      }
    }

    const pdfBlob = pdf.output('blob');
    const safeName = (submission.contact.name || 'lead').replace(/[^a-z0-9]+/gi, '-').replace(/^-+|-+$/g, '');
    const filename = `Brand-Voice-Sheet-${safeName}.pdf`;
    return { filename, blob: pdfBlob, sizeKB: Math.round(pdfBlob.size / 1024) };
  } catch (err) {
    console.warn('PDF generation failed:', err);
    return null;
  }
}

function blobToBase64(blob){
  return new Promise((resolve, reject) => {
    const r = new FileReader();
    r.onloadend = () => {
      const s = (r.result || '').toString();
      resolve(s.includes(',') ? s.split(',')[1] : s);
    };
    r.onerror = reject;
    r.readAsDataURL(blob);
  });
}

