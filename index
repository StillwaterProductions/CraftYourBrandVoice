document.getElementById('contactForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const contact = {
    name:  (fd.get('name') || '').toString().trim(),
    email: (fd.get('email') || '').toString().trim(),
    phone: (fd.get('phone') || '').toString().trim(),
  };
  if (!contact.name || !contact.email || !contact.phone) return;

  // record submission
  const submission = {
    id: 'sub_' + Math.random().toString(36).slice(2,10),
    createdAt: new Date().toISOString(),
    contact,
    answers: JSON.parse(JSON.stringify(state)),
  };
  saveSubmission(submission);

  // close modal, open result view + wait for voice statement to render
  closeContact();
  await openResult(submission);

  // generate PDF from the rendered sheet, then POST everything to Zapier
  setSendStatus('Preparing your PDF…');
  const pdf = await generateSheetPDF(submission);
  const voiceStatement = document.getElementById('rv-statement').textContent.trim();

  setSendStatus('Sending…');
  await postToZapier(submission, { voiceStatement, pdf });

  // persist PDF reference + final statement back into the saved submission
  try {
    const all = loadSubmissions();
    const i = all.findIndex(s => s.id === submission.id);
    if (i >= 0) {
      all[i].voiceStatement = voiceStatement;
      if (pdf) all[i].pdfFilename = pdf.filename;
      localStorage.setItem(STORE_KEY, JSON.stringify(all));
    }
  } catch(e){}

  setSendStatus(pdf ? 'Sent ✓' : 'Sent (without PDF)', true);
});

//
// =============== ADMIN STORAGE ===============
//
function saveSubmission(sub){
  let all = [];
  try { all = JSON.parse(localStorage.getItem(STORE_KEY) || '[]') || []; } catch(e){}
  all.unshift(sub);
  try { localStorage.setItem(STORE_KEY, JSON.stringify(all)); } catch(e){}
}
function loadSubmissions(){
  try { return JSON.parse(localStorage.getItem(STORE_KEY) || '[]') || []; } catch(e){ return []; }
}

//
// =============== RESULT VIEW RENDER ===============
//
const resultView = document.getElementById('resultView');
document.getElementById('rv-back').addEventListener('click', () => {
  resultView.classList.remove('show');
  resultView.setAttribute('aria-hidden','true');
});
document.getElementById('rv-book').addEventListener('click', () => {
  alert('Booking link: stillwaterproductions.com/book-a-call');
});

async function openResult(sub){
  const a = sub.answers;
  const f = a.fields || {};

  document.getElementById('rv-name').textContent = sub.contact.name;
  document.getElementById('rv-forname').textContent = sub.contact.name;
  document.getElementById('rv-date').textContent = new Date(sub.createdAt).toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });

  document.getElementById('rv-mission').textContent = f.mission || '—';
  document.getElementById('rv-vision').textContent  = f.vision || '—';
  document.getElementById('rv-pitch').textContent   = f.pitch  || '—';

  // words
  const wEl = document.getElementById('rv-words');
  wEl.innerHTML = '';
  (a.words || []).forEach(w => {
    const s = document.createElement('span'); s.className = 'sheet-word'; s.textContent = w; wEl.appendChild(s);
  });

  // voice chart
  const cEl = document.getElementById('rv-chart');
  cEl.innerHTML = '';
  const picks = (a.words || []).filter(w => WORD_MAP[w]);
  if (picks.length) {
    picks.forEach(w => {
      const m = WORD_MAP[w];
      const row = document.createElement('div');
      row.className = 'sheet-vc-row';
      row.innerHTML = `<div class="w">${escapeHTML(w)}</div><div class="d">\u201c${escapeHTML(m.doThis.replace(/^[\u201c"]|[\u201d"]$/g,''))}\u201d</div><div class="n">\u201c${escapeHTML(m.notThis.replace(/^[\u201c"]|[\u201d"]$/g,''))}\u201d</div>`;
      cEl.appendChild(row);
    });
  } else {
    cEl.innerHTML = '<div style="font-family:var(--font-serif); font-style:italic; color:var(--lagoon-60); font-size:18px;">Pick three words in Step 03 to populate this chart.</div>';
  }

  // tones — only show rows that moved off-center
  const tEl = document.getElementById('rv-tones');
  tEl.innerHTML = '';
  toneRows.forEach((row, idx) => {
    const pct = a.tones[idx] ?? 50;
    if (Math.abs(pct - 50) < 8) return;
    const l = row.dataset.l, r = row.dataset.r;
    const wrap = document.createElement('div');
    wrap.className = 'sheet-tone';
    wrap.innerHTML = `
      <div class="e l ${pct<40?'active':''}">${l}</div>
      <div class="bar"><i style="left:${pct}%;"></i></div>
      <div class="e r ${pct>60?'active':''}">${r}</div>`;
    tEl.appendChild(wrap);
  });
  if (!tEl.children.length) {
    tEl.innerHTML = '<div style="font-family:var(--font-serif); font-style:italic; color:var(--lagoon-60); font-size:18px;">No tones set — try moving the sliders in Step 03.</div>';
  }

  // strengths
  const sEl = document.getElementById('rv-strengths');
  sEl.innerHTML = '';
  [1,2,3,4,5].forEach(i => {
    const v = f['strength-'+i]; if (!v) return;
    const li = document.createElement('li'); li.textContent = v; sEl.appendChild(li);
  });

  // pillars
  const pEl = document.getElementById('rv-pillars');
  const pillarNames = ['The Neighborhood', 'The Process', 'The Person'];
  pEl.innerHTML = '';
  [1,2,3].forEach(i => {
    const v = f['pillar-'+i]; if (!v) return;
    const card = document.createElement('div');
    card.className = 'pillar-card';
    card.innerHTML = `<div class="h">Pillar 0${i} · ${pillarNames[i-1]}</div><p class="p">${escapeHTML(v)}</p>`;
    pEl.appendChild(card);
  });

  // show view
  resultView.classList.add('show');
  resultView.setAttribute('aria-hidden','false');
  resultView.scrollTo(0, 0);

  // generate voice statement (awaited so caller can wait for full sheet to render before PDF)
  await generateVoiceStatement(sub);
}

function escapeHTML(s){
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

async function generateVoiceStatement(sub){
  const stmtEl = document.getElementById('rv-statement');
  const a = sub.answers;
  const f = a.fields || {};

  // build the dominant tone summary
  const tones = toneRows.map((row, idx) => {
    const pct = a.tones[idx] ?? 50;
    if (Math.abs(pct - 50) < 8) return null;
    return pct < 50 ? row.dataset.l : row.dataset.r;
  }).filter(Boolean);

  const prompt = `You are a brand strategist writing for a real estate professional. In ONE sentence (max 32 words), describe their brand voice in second person ("Your voice is..."). Use plain English, no hype, no exclamation points, no emoji. Reference their voice words and dominant tones naturally — do not list them.

Name: ${sub.contact.name}
Mission: ${f.mission || '—'}
Voice words: ${(a.words || []).join(', ') || '—'}
Dominant tones: ${tones.join(', ') || '—'}

Reply with ONLY the single sentence. No preamble, no quotes.`;

  // fallback statement if claude is unavailable
  const fallback = makeFallbackStatement(sub);

  let finalText = fallback;
  try {
    if (window.claude && typeof window.claude.complete === 'function') {
      const out = await window.claude.complete(prompt);
      const cleaned = (out || '').toString().trim().replace(/^["'\u201C\u2018]|["'\u201D\u2019]$/g, '');
      finalText = cleaned || fallback;
    }
  } catch (err) {
    finalText = fallback;
  }
  stmtEl.textContent = finalText;

  // persist generated statement back into the submission
  try {
    const all = loadSubmissions();
    const i = all.findIndex(s => s.id === sub.id);
    if (i >= 0) { all[i].voiceStatement = finalText; localStorage.setItem(STORE_KEY, JSON.stringify(all)); }
  } catch(e){}

  return finalText;
}

function makeFallbackStatement(sub){
  const a = sub.answers;
  const words = (a.words || []).slice(0, 3);
  const tones = toneRows.map((row, idx) => {
    const pct = a.tones[idx] ?? 50;
    if (Math.abs(pct - 50) < 8) return null;
    return pct < 50 ? row.dataset.l : row.dataset.r;
  }).filter(Boolean).slice(0, 2);
  const wordPart = words.length ? words.join(', ').toLowerCase() : 'clear and grounded';
  const tonePart = tones.length ? ' with a ' + tones.join(', ').toLowerCase() + ' edge' : '';
  return `Your voice is ${wordPart}${tonePart} — written like a person, not a brochure, and always pointed at one clear next step for the reader.`;
}


//
// =============== ADMIN VIEW ===============
//
function isAdmin(){
  const p = new URLSearchParams(location.search);
  return p.has('admin');
}
if (isAdmin()){
  document.body.classList.add('admin');
  renderAdmin();
}
function renderAdmin(){
  const subs = loadSubmissions();
  const rows = document.getElementById('adminRows');
  const empty = document.getElementById('adminEmpty');
  rows.innerHTML = '';
  if (!subs.length) { empty.style.display = ''; return; }
  empty.style.display = 'none';
  subs.forEach(s => {
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td>${new Date(s.createdAt).toLocaleString()}</td>
      <td><b>${escapeHTML(s.contact.name)}</b></td>
      <td>${escapeHTML(s.contact.email)}</td>
      <td>${escapeHTML(s.contact.phone)}</td>
      <td>${(s.answers.words || []).slice(0,4).join(', ')}${(s.answers.words||[]).length>4 ? '…' : ''}</td>
      <td><button class="toolbtn" type="button" data-view="${s.id}">Open sheet</button></td>`;
    rows.appendChild(tr);
  });
  rows.addEventListener('click', e => {
    const b = e.target.closest('[data-view]');
    if (!b) return;
    const id = b.getAttribute('data-view');
    const sub = loadSubmissions().find(s => s.id === id);
    if (sub) openResult(sub);
  });
}
document.getElementById('adminExport').addEventListener('click', () => {
  const data = JSON.stringify(loadSubmissions(), null, 2);
  const blob = new Blob([data], { type:'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = 'stillwater-brand-voice-submissions.json';
  document.body.appendChild(a); a.click(); a.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
});
document.getElementById('adminClear').addEventListener('click', () => {
  if (confirm('Clear all stored submissions on this device? This cannot be undone.')) {
    localStorage.removeItem(STORE_KEY);
    renderAdmin();
  }
});

