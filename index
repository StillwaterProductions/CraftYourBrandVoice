function computeCompletion(){
  const f = state.fields || {};
  const checks = {
    essentials: !!(f.mission && f.vision && f.pitch),
    words:      state.words.length >= 3,
    chart:      state.words.length >= 3,
    tone:       Object.values(state.tones).some(v => Math.abs(v - 50) > 8),
    strengths:  [1,2,3,4,5].filter(i => f['strength-'+i]).length >= 3,
    pillars:    [1,2,3].filter(i => f['pillar-'+i]).length >= 2,
  };
  return checks;
}
function updateProgress(){
  const c = computeCompletion();
  const total = Object.keys(c).length;
  const done = Object.values(c).filter(Boolean).length;
  const pct = Math.round((done/total) * 100);
  document.getElementById('progressFill').style.right = (100 - pct) + '%';
  document.getElementById('progressNum').textContent = pct;
  document.querySelectorAll('[data-check]').forEach(el => {
    el.classList.toggle('done', !!c[el.getAttribute('data-check')]);
  });
}
